---
import Layout from '../../layouts/Layout.astro';
import { languages } from '../../i18n/ui';
import { useTranslations } from '../../i18n/utils';
import PageHeader from '../../components/PageHeader.astro';

export function getStaticPaths() {
  return Object.keys(languages).map(lang => ({ params: { lang } }));
}

const { lang } = Astro.params;
const t = useTranslations(lang as any);

// Sea Freight Services - Only sea freight content
const seaFreightServices = [
  {
    title: 'Full Container Load (FCL)',
    description: '20ft, 40ft standard containers and 40ft high cube options for bulk cargo transport.',
    features: ['Dedicated Container', 'High Security', 'Efficient Loading', 'Bulk Cargo']
  },
  {
    title: 'Less than Container Load (LCL)',
    description: 'Consolidate multiple shipments in one container to reduce costs for smaller volumes.',
    features: ['Cost Sharing', 'Flexible Volume', 'Door-to-Door', 'Global Coverage']
  },
  {
    title: 'Bulk & Break Bulk',
    description: 'Professional bulk cargo shipping including commodities, project cargo, and oversized items.',
    features: ['Specialized Loading', 'Lashing & Securing', 'Project Cargo', 'Bulk Commodities']
  },
  {
    title: 'Special Equipment',
    description: 'Open top, flat rack, reefer, and tank container transport for specialized cargo.',
    features: ['Open Top', 'Flat Rack', 'Reefer', 'Tank Container']
  }
];

// Air Freight Services - Only air freight content
const airFreightServices = [
  {
    title: 'International Air Freight',
    description: 'Global air freight services between major airports worldwide, fast and reliable.',
    features: ['Fast Transit', 'Secure & Reliable', 'Global Network', 'High-Value Cargo']
  },
  {
    title: 'Air Freight Express',
    description: 'Dedicated air freight on specific routes with guaranteed flight schedules.',
    features: ['Fixed Flights', 'Guaranteed Space', 'Time-Definite', 'Priority Handling']
  },
  {
    title: 'Express Courier',
    description: 'Door-to-door courier services in partnership with international express companies.',
    features: ['Door-to-Door', 'Real-Time Tracking', 'Small Packages', 'Fast Clearance']
  },
  {
    title: 'Dangerous Goods Air',
    description: 'Licensed dangerous goods air freight including lithium batteries and chemicals.',
    features: ['Licensed Operator', 'Compliant Operations', 'Safety Assurance', 'Full Monitoring']
  }
];

// Major Routes Data
const seaRoutes = [
  { name: 'China → Europe', ports: 'Shanghai/Ningbo → Rotterdam/Hamburg/Antwerp' },
  { name: 'China → North America', ports: 'Shenzhen/Qingdao → Los Angeles/Long Beach/New York' },
  { name: 'China → Southeast Asia', ports: 'Guangzhou/Xiamen → Singapore/Port Klang/Bangkok' },
  { name: 'China → Middle East', ports: 'Tianjin/Dalian → Dubai/Jebel Ali/Doha' }
];

const airRoutes = [
  { name: 'China → Europe', airports: 'Beijing/Shanghai → Frankfurt/Amsterdam/London' },
  { name: 'China → North America', airports: 'Guangzhou/Shenzhen → Los Angeles/Chicago/New York' },
  { name: 'China → Southeast Asia', airports: 'Kunming/Chengdu → Singapore/Bangkok/Kuala Lumpur' },
  { name: 'China → Japan & Korea', airports: 'Shanghai/Dalian → Tokyo/Seoul/Osaka' }
];
---

<Layout title={`${t('logistics.title')} - ${t('site.name')}`}>
  <PageHeader
    title={t('logistics.title')}
    subtitle={t('logistics.subtitle')}
    bgImage="https://images.unsplash.com/photo-1494412574643-ff11b0a5c1c3?auto=format&fit=crop&q=80&w=2070"
    textColor="white"
  />

  <!-- Sea Freight Section -->
  <section class="section-padding bg-white" id="sea-freight">
    <div class="container">
      <!-- Section Header -->
      <div class="text-center mb-16">
        <div class="inline-flex items-center justify-center gap-4 mb-6">
          <div class="w-20 h-1 bg-gradient-to-r from-transparent to-accent rounded-full"></div>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-14 w-14 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
          </svg>
          <div class="w-20 h-1 bg-gradient-to-l from-transparent to-accent rounded-full"></div>
        </div>
        <h2 class="text-4xl md:text-6xl font-bold font-serif text-primary mb-6 drop-shadow-sm">
          Sea Freight - International Logistics
        </h2>
        <p class="text-xl text-gray-700 max-w-3xl mx-auto leading-relaxed">
          Professional sea freight services covering major ports worldwide with FCL, LCL, and bulk cargo solutions
        </p>
      </div>

      <!-- Hero Image for Sea Freight -->
      <div class="mb-16 relative rounded-3xl overflow-hidden shadow-2xl">
        <img 
          src="https://images.unsplash.com/photo-1494412574643-ff11b0a5c1c3?auto=format&fit=crop&q=80&w=2070" 
          alt="Sea Freight Container Ship" 
          class="w-full h-80 md:h-[500px] object-cover"
        />
        <div class="absolute inset-0 bg-gradient-to-t from-primary via-primary/60 to-transparent"></div>
        <div class="absolute bottom-0 left-0 right-0 p-8 md:p-12">
          <div class="bg-white/10 backdrop-blur-md rounded-2xl p-6 md:p-8 border border-white/20">
            <h3 class="text-3xl md:text-5xl font-bold text-white mb-4" style="text-shadow: 0 4px 20px rgba(0,0,0,0.5), 0 2px 4px rgba(0,0,0,0.3);">Global Sea Freight Network</h3>
            <p class="text-white text-lg md:text-xl max-w-2xl leading-relaxed" style="text-shadow: 0 2px 10px rgba(0,0,0,0.4);">
              Long-term partnerships with major shipping lines ensure reliable space allocation and competitive rates
            </p>
          </div>
        </div>
        <!-- Wave decoration -->
        <div class="absolute bottom-0 left-0 right-0 h-16 opacity-20">
          <svg viewBox="0 0 1440 320" class="w-full h-full fill-white">
            <path d="M0,224L48,213.3C96,203,192,181,288,181.3C384,181,480,203,576,218.7C672,235,768,245,864,234.7C960,224,1056,192,1152,181.3C1248,171,1344,181,1392,186.7L1440,192L1440,320L1392,320C1344,320,1248,320,1152,320C1056,320,960,320,864,320C768,320,672,320,576,320C480,320,384,320,288,320C192,320,96,320,48,320L0,320Z"></path>
          </svg>
        </div>
      </div>

      <!-- Sea Freight Services Grid -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        {seaFreightServices.map((service, index) => (
          <div class="bg-gradient-to-br from-slate-50 to-white rounded-2xl shadow-lg border border-gray-200 overflow-hidden hover:shadow-2xl hover:border-accent/30 transition-all duration-300 group">
            <div class="p-8">
              <div class="flex items-start gap-6">
                <div class="w-16 h-16 bg-primary/10 rounded-xl flex items-center justify-center shrink-0 group-hover:bg-primary/20 transition-colors">
                  <span class="text-3xl font-bold text-primary">{String(index + 1).padStart(2, '0')}</span>
                </div>
                <div class="flex-1">
                  <h3 class="text-2xl font-bold text-primary mb-3 group-hover:text-accent transition-colors">{service.title}</h3>
                  <p class="text-gray-600 leading-relaxed mb-4">{service.description}</p>
                  
                  <div class="grid grid-cols-2 gap-3">
                    {service.features.map((feature) => (
                      <div class="flex items-center gap-2">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-accent shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                        </svg>
                        <span class="text-gray-700 font-medium">{feature}</span>
                      </div>
                    ))}
                  </div>
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Air Freight Section -->
  <section class="section-padding bg-gradient-to-br from-slate-100 to-white" id="air-freight">
    <div class="container">
      <!-- Section Header -->
      <div class="text-center mb-16">
        <div class="inline-flex items-center justify-center gap-4 mb-6">
          <div class="w-20 h-1 bg-gradient-to-r from-transparent to-accent rounded-full"></div>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-14 w-14 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8" />
          </svg>
          <div class="w-20 h-1 bg-gradient-to-l from-transparent to-accent rounded-full"></div>
        </div>
        <h2 class="text-4xl md:text-6xl font-bold font-serif text-primary mb-6 drop-shadow-sm">
          Air Freight - International Logistics
        </h2>
        <p class="text-xl text-gray-700 max-w-3xl mx-auto leading-relaxed">
          Fast and efficient air freight services covering major airports worldwide for your urgent cargo needs
        </p>
      </div>

      <!-- Hero Image for Air Freight -->
      <div class="mb-16 relative rounded-3xl overflow-hidden shadow-2xl">
        <img 
          src="https://images.unsplash.com/photo-1436491865332-7a61a109cc05?auto=format&fit=crop&q=80&w=2070" 
          alt="Air Freight Cargo Plane" 
          class="w-full h-80 md:h-[500px] object-cover"
        />
        <div class="absolute inset-0 bg-gradient-to-t from-primary via-primary/60 to-transparent"></div>
        <div class="absolute bottom-0 left-0 right-0 p-8 md:p-12">
          <div class="bg-white/10 backdrop-blur-md rounded-2xl p-6 md:p-8 border border-white/20">
            <h3 class="text-3xl md:text-5xl font-bold text-white mb-4" style="text-shadow: 0 4px 20px rgba(0,0,0,0.5), 0 2px 4px rgba(0,0,0,0.3);">Global Air Freight Network</h3>
            <p class="text-white text-lg md:text-xl max-w-2xl leading-relaxed" style="text-shadow: 0 2px 10px rgba(0,0,0,0.4);">
              Partnerships with major airlines provide guaranteed space allocation and priority handling services
            </p>
          </div>
        </div>
        <!-- Cloud decoration -->
        <div class="absolute top-8 right-8 opacity-20">
          <svg class="w-32 h-32 fill-white" viewBox="0 0 24 24">
            <path d="M19.35 10.04C18.67 6.59 15.64 4 12 4 9.11 4 6.6 5.64 5.35 8.04 2.34 8.36 0 10.91 0 14c0 3.31 2.69 6 6 6h13c2.76 0 5-2.24 5-5 0-2.64-2.05-4.78-4.65-4.96z"/>
          </svg>
        </div>
      </div>

      <!-- Air Freight Services Grid -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        {airFreightServices.map((service, index) => (
          <div class="bg-white rounded-2xl shadow-lg border border-gray-200 overflow-hidden hover:shadow-2xl hover:border-accent/30 transition-all duration-300 group">
            <div class="p-8">
              <div class="flex items-start gap-6">
                <div class="w-16 h-16 bg-accent/10 rounded-xl flex items-center justify-center shrink-0 group-hover:bg-accent/20 transition-colors">
                  <span class="text-3xl font-bold text-accent">{String(index + 1).padStart(2, '0')}</span>
                </div>
                <div class="flex-1">
                  <h3 class="text-2xl font-bold text-primary mb-3 group-hover:text-accent transition-colors">{service.title}</h3>
                  <p class="text-gray-600 leading-relaxed mb-4">{service.description}</p>
                  
                  <div class="grid grid-cols-2 gap-3">
                    {service.features.map((feature) => (
                      <div class="flex items-center gap-2">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-accent shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                        </svg>
                        <span class="text-gray-700 font-medium">{feature}</span>
                      </div>
                    ))}
                  </div>
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Stats Section -->
  <section class="py-20 bg-gradient-to-br from-primary to-primary-light text-white relative overflow-hidden">
    <div class="absolute inset-0 opacity-10">
      <div class="absolute inset-0" style="background-image: radial-gradient(circle at 1px 1px, rgba(255,255,255,0.3) 1px, transparent 0); background-size: 40px 40px;"></div>
    </div>
    
    <div class="container relative z-10">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold mb-4 text-white" style="text-shadow: 0 4px 20px rgba(0,0,0,0.4);">Our Strength</h2>
        <p class="text-white text-lg" style="text-shadow: 0 2px 10px rgba(0,0,0,0.3);">Years of expertise in logistics, providing professional and reliable services</p>
      </div>
      
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
        <div class="text-center bg-white/15 rounded-2xl p-6 backdrop-blur-md border border-white/20">
          <div class="text-5xl md:text-6xl font-bold mb-3 text-accent" style="text-shadow: 0 4px 20px rgba(0,0,0,0.5);">80+</div>
          <div class="text-white text-lg font-medium" style="text-shadow: 0 2px 10px rgba(0,0,0,0.3);">Countries Served</div>
        </div>
        <div class="text-center bg-white/15 rounded-2xl p-6 backdrop-blur-md border border-white/20">
          <div class="text-5xl md:text-6xl font-bold mb-3 text-accent" style="text-shadow: 0 4px 20px rgba(0,0,0,0.5);">240+</div>
          <div class="text-white text-lg font-medium" style="text-shadow: 0 2px 10px rgba(0,0,0,0.3);">Service Points</div>
        </div>
        <div class="text-center bg-white/15 rounded-2xl p-6 backdrop-blur-md border border-white/20">
          <div class="text-5xl md:text-6xl font-bold mb-3 text-accent" style="text-shadow: 0 4px 20px rgba(0,0,0,0.5);">1000+</div>
          <div class="text-white text-lg font-medium" style="text-shadow: 0 2px 10px rgba(0,0,0,0.3);">Global Clients</div>
        </div>
        <div class="text-center bg-white/15 rounded-2xl p-6 backdrop-blur-md border border-white/20">
          <div class="text-5xl md:text-6xl font-bold mb-3 text-accent" style="text-shadow: 0 4px 20px rgba(0,0,0,0.5);">24/7</div>
          <div class="text-white text-lg font-medium" style="text-shadow: 0 2px 10px rgba(0,0,0,0.3);">Round-the-Clock</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Routes Map Section with Animation -->
  <section class="section-padding bg-slate-50">
    <div class="container">
      <div class="text-center mb-16">
        <h2 class="text-4xl md:text-5xl font-bold font-serif text-primary mb-6">Major Routes</h2>
        <p class="text-xl text-gray-700 max-w-2xl mx-auto font-medium">Covering major ports and airports worldwide, providing efficient logistics channels</p>
      </div>

      <!-- Sea Routes -->
      <div class="mb-16">
        <h3 class="text-2xl font-bold text-primary mb-8 flex items-center gap-3">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
          </svg>
          Sea Routes
        </h3>
        <div class="bg-white rounded-2xl shadow-lg p-8 border border-gray-200">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            {seaRoutes.map((route) => (
              <div class="route-card flex items-center gap-4 p-5 bg-gradient-to-r from-blue-50 to-white rounded-xl border-2 border-gray-200 hover:shadow-lg hover:border-accent/50 transition-all group">
                <div class="w-14 h-14 bg-primary rounded-xl flex items-center justify-center shrink-0 group-hover:bg-accent transition-colors shadow-md">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                  </svg>
                </div>
                <div class="flex-1">
                  <div class="font-bold text-primary text-lg mb-1 group-hover:text-accent transition-colors">{route.name}</div>
                  <div class="text-gray-600 text-sm font-medium">{route.ports}</div>
                </div>
                <div class="route-line">
                  <svg class="w-24 h-8" viewBox="0 0 100 30">
                    <path class="route-dash" d="M0,15 Q25,0 50,15 T100,15" fill="none" stroke="#FF9900" stroke-width="2.5" stroke-dasharray="5,5"/>
                    <circle cx="0" cy="15" r="5" fill="#003366"/>
                    <circle cx="100" cy="15" r="5" fill="#FF9900"/>
                  </svg>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>

      <!-- Air Routes -->
      <div>
        <h3 class="text-2xl font-bold text-primary mb-8 flex items-center gap-3">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8" />
          </svg>
          Air Routes
        </h3>
        <div class="bg-white rounded-2xl shadow-lg p-8 border border-gray-200">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            {airRoutes.map((route) => (
              <div class="route-card flex items-center gap-4 p-5 bg-gradient-to-r from-orange-50 to-white rounded-xl border-2 border-gray-200 hover:shadow-lg hover:border-accent/50 transition-all group">
                <div class="w-14 h-14 bg-accent rounded-xl flex items-center justify-center shrink-0 shadow-md">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8" />
                  </svg>
                </div>
                <div class="flex-1">
                  <div class="font-bold text-primary text-lg mb-1 group-hover:text-accent transition-colors">{route.name}</div>
                  <div class="text-gray-600 text-sm font-medium">{route.airports}</div>
                </div>
                <div class="route-line">
                  <svg class="w-24 h-8" viewBox="0 0 100 30">
                    <path class="route-dash" d="M0,15 Q25,30 50,15 T100,15" fill="none" stroke="#003366" stroke-width="2.5" stroke-dasharray="5,5"/>
                    <circle cx="0" cy="15" r="5" fill="#003366"/>
                    <circle cx="100" cy="15" r="5" fill="#FF9900"/>
                  </svg>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-24 bg-gradient-to-br from-primary via-primary-light to-primary text-white relative overflow-hidden">
    <div class="absolute inset-0 opacity-5">
      <svg class="w-full h-full" viewBox="0 0 100 100" preserveAspectRatio="none">
        <defs>
          <pattern id="grid" width="10" height="10" patternUnits="userSpaceOnUse">
            <path d="M 10 0 L 0 0 0 10" fill="none" stroke="white" stroke-width="0.5"/>
          </pattern>
        </defs>
        <rect width="100%" height="100%" fill="url(#grid)"/>
      </svg>
    </div>
    
    <!-- Decorative elements -->
    <div class="absolute top-10 left-10 opacity-10">
      <svg class="w-40 h-40 fill-white" viewBox="0 0 24 24">
        <path d="M12 2L1 21h22L12 2zm0 3.99L19.53 19H4.47L12 5.99z"/>
      </svg>
    </div>
    <div class="absolute bottom-10 right-10 opacity-10">
      <svg class="w-32 h-32 fill-white" viewBox="0 0 24 24">
        <path d="M20 8h-3V4H3c-1.1 0-2 .9-2 2v11h2c0 1.66 1.34 3 3 3s3-1.34 3-3h6c0 1.66 1.34 3 3 3s3-1.34 3-3h2v-5l-3-4zM6 18.5c-.83 0-1.5-.67-1.5-1.5s.67-1.5 1.5-1.5 1.5.67 1.5 1.5-.67 1.5-1.5 1.5zm13.5-9l1.96 2.5H17V9.5h2.5zm-1.5 9c-.83 0-1.5-.67-1.5-1.5s.67-1.5 1.5-1.5 1.5.67 1.5 1.5-.67 1.5-1.5 1.5z"/>
      </svg>
    </div>
    
    <div class="container relative z-10">
      <div class="max-w-4xl mx-auto text-center">
        <div class="bg-white/10 backdrop-blur-md rounded-3xl p-8 md:p-12 border border-white/20">
          <h2 class="text-4xl md:text-5xl font-bold mb-6 text-white" style="text-shadow: 0 4px 20px rgba(0,0,0,0.5), 0 2px 4px rgba(0,0,0,0.3);">Professional Logistics for Global Trade</h2>
          <p class="text-xl text-white mb-10 leading-relaxed" style="text-shadow: 0 2px 10px rgba(0,0,0,0.4);">
            Whether you need sea freight or air freight services, we provide optimal logistics solutions. Contact us to start your global trade journey.
          </p>
          <div class="flex flex-col sm:flex-row gap-6 justify-center">
            <a href={`/${lang}/contact`} class="bg-accent hover:bg-accent-hover text-white px-10 py-5 rounded-full font-bold text-lg inline-flex items-center justify-center gap-3 transition-all shadow-2xl hover:shadow-accent/30 transform hover:-translate-y-1">
              Contact Us
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </a>
            <a href="tel:+868392339988" class="bg-white/20 hover:bg-white/30 text-white border-2 border-white/60 px-10 py-5 rounded-full font-bold text-lg inline-flex items-center justify-center gap-3 transition-all backdrop-blur-sm">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
