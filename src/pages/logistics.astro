---
import Layout from '../layouts/Layout.astro';
import { useTranslations } from '../i18n/utils';
import PageHeader from '../components/PageHeader.astro';

// Use zh as default language for root path
const lang = 'zh';
const t = useTranslations(lang);

// 海运服务 - 只包含海运相关内容
const seaFreightServices = [
  {
    title: '整箱运输 (FCL)',
    description: '提供20尺、40尺标准集装箱及40尺高柜等多种规格选择，适合大批量货物运输。',
    icon: 'container',
    features: ['专属集装箱', '安全性高', '装卸效率高', '适合大宗货物']
  },
  {
    title: '拼箱运输 (LCL)',
    description: '将多个发货人的货物拼装在一个集装箱内，降低小批量货物的运输成本。',
    icon: 'boxes',
    features: ['成本分摊', '灵活起运', '门到门服务', '全球覆盖']
  },
  {
    title: '散杂货运输',
    description: '专业承接散杂货船运服务，包括大宗散货、项目货物、超重超宽货物等。',
    icon: 'cargo',
    features: ['专业装卸', '绑扎加固', '项目物流', '大宗散货']
  },
  {
    title: '特种柜运输',
    description: '提供开顶柜、框架柜、冷藏柜、罐式柜等特种集装箱运输服务。',
    icon: 'special',
    features: ['开顶柜', '框架柜', '冷藏柜', '罐式柜']
  }
];

// 空运服务 - 只包含空运相关内容
const airFreightServices = [
  {
    title: '国际空运',
    description: '提供全球主要机场之间的空运服务，时效快速，安全可靠。',
    icon: 'plane',
    features: ['时效快速', '安全可靠', '全球网络', '高价值货物']
  },
  {
    title: '空运专线',
    description: '针对特定航线提供固定航班、固定舱位的专线服务，确保货物按时到达。',
    icon: 'route',
    features: ['固定航班', '固定舱位', '时效保障', '优先处理']
  },
  {
    title: '快递服务',
    description: '与国际知名快递公司合作，提供门到门快递服务，适合小件急件。',
    icon: 'express',
    features: ['门到门服务', '实时追踪', '小件急件', '快速通关']
  },
  {
    title: '危险品空运',
    description: '具备危险品空运资质，可承接锂电池、化学品等危险品的空运服务。',
    icon: 'danger',
    features: ['专业资质', '合规操作', '安全保障', '全程监控']
  }
];

// 主要航线数据
const seaRoutes = [
  { name: '中国 → 欧洲', ports: '上海/宁波 → 鹿特丹/汉堡/安特卫普' },
  { name: '中国 → 北美', ports: '深圳/青岛 → 洛杉矶/长滩/纽约' },
  { name: '中国 → 东南亚', ports: '广州/厦门 → 新加坡/巴生港/曼谷' },
  { name: '中国 → 中东', ports: '天津/大连 → 迪拜/杰贝阿里/多哈' }
];

const airRoutes = [
  { name: '中国 → 欧洲航线', airports: '北京/上海 → 法兰克福/阿姆斯特丹/伦敦' },
  { name: '中国 → 北美航线', airports: '广州/深圳 → 洛杉矶/芝加哥/纽约' },
  { name: '中国 → 东南亚航线', airports: '昆明/成都 → 新加坡/曼谷/吉隆坡' },
  { name: '中国 → 日韩航线', airports: '上海/大连 → 东京/首尔/大阪' }
];
---

<Layout title={`${t('logistics.title')} - ${t('site.name')}`}>
  <PageHeader
    title={t('logistics.title')}
    subtitle={t('logistics.subtitle')}
    bgImage="https://images.unsplash.com/photo-1494412574643-ff11b0a5c1c3?auto=format&fit=crop&q=80&w=2070"
    textColor="white"
  />

  <!-- 海运-国际物流 Section -->
  <section class="section-padding bg-white" id="sea-freight">
    <div class="container">
      <!-- Section Header -->
      <div class="text-center mb-16">
        <div class="inline-flex items-center justify-center gap-4 mb-6">
          <div class="w-20 h-1 bg-gradient-to-r from-transparent to-accent rounded-full"></div>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-14 w-14 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
          </svg>
          <div class="w-20 h-1 bg-gradient-to-l from-transparent to-accent rounded-full"></div>
        </div>
        <h2 class="text-4xl md:text-6xl font-bold font-serif text-primary mb-6 drop-shadow-sm">
          海运-国际物流
        </h2>
        <p class="text-xl text-gray-700 max-w-3xl mx-auto leading-relaxed">
          专业海运服务，覆盖全球主要港口，提供整箱、拼箱、散杂货等多种运输方案
        </p>
      </div>

      <!-- Hero Image for Sea Freight -->
      <div class="mb-16 relative rounded-3xl overflow-hidden shadow-2xl">
        <img 
          src="https://images.unsplash.com/photo-1494412574643-ff11b0a5c1c3?auto=format&fit=crop&q=80&w=2070" 
          alt="海运集装箱货船" 
          class="w-full h-80 md:h-[500px] object-cover"
        />
        <div class="absolute inset-0 bg-gradient-to-t from-primary via-primary/60 to-transparent"></div>
        <div class="absolute bottom-0 left-0 right-0 p-8 md:p-12">
          <div class="bg-white/10 backdrop-blur-md rounded-2xl p-6 md:p-8 border border-white/20">
            <h3 class="text-3xl md:text-5xl font-bold text-white mb-4" style="text-shadow: 0 4px 20px rgba(0,0,0,0.5), 0 2px 4px rgba(0,0,0,0.3);">全球海运网络</h3>
            <p class="text-white text-lg md:text-xl max-w-2xl leading-relaxed" style="text-shadow: 0 2px 10px rgba(0,0,0,0.4);">
              与全球主流船公司建立长期合作关系，提供稳定舱位和优惠运价，确保货物安全准时到达
            </p>
          </div>
        </div>
        <!-- 波浪装饰 -->
        <div class="absolute bottom-0 left-0 right-0 h-16 opacity-20">
          <svg viewBox="0 0 1440 320" class="w-full h-full fill-white">
            <path d="M0,224L48,213.3C96,203,192,181,288,181.3C384,181,480,203,576,218.7C672,235,768,245,864,234.7C960,224,1056,192,1152,181.3C1248,171,1344,181,1392,186.7L1440,192L1440,320L1392,320C1344,320,1248,320,1152,320C1056,320,960,320,864,320C768,320,672,320,576,320C480,320,384,320,288,320C192,320,96,320,48,320L0,320Z"></path>
          </svg>
        </div>
      </div>

      <!-- Sea Freight Services Grid -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        {seaFreightServices.map((service, index) => (
          <div class="bg-gradient-to-br from-slate-50 to-white rounded-2xl shadow-lg border border-gray-200 overflow-hidden hover:shadow-2xl hover:border-accent/30 transition-all duration-300 group">
            <div class="p-8">
              <div class="flex items-start gap-6">
                <div class="w-16 h-16 bg-primary/10 rounded-xl flex items-center justify-center shrink-0 group-hover:bg-primary/20 transition-colors">
                  <span class="text-3xl font-bold text-primary">{String(index + 1).padStart(2, '0')}</span>
                </div>
                <div class="flex-1">
                  <h3 class="text-2xl font-bold text-primary mb-3 group-hover:text-accent transition-colors">{service.title}</h3>
                  <p class="text-gray-600 leading-relaxed mb-4">{service.description}</p>
                  
                  <div class="grid grid-cols-2 gap-3">
                    {service.features.map((feature) => (
                      <div class="flex items-center gap-2">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-accent shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                        </svg>
                        <span class="text-gray-700 font-medium">{feature}</span>
                      </div>
                    ))}
                  </div>
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 空运-国际物流 Section -->
  <section class="section-padding bg-gradient-to-br from-slate-100 to-white" id="air-freight">
    <div class="container">
      <!-- Section Header -->
      <div class="text-center mb-16">
        <div class="inline-flex items-center justify-center gap-4 mb-6">
          <div class="w-20 h-1 bg-gradient-to-r from-transparent to-accent rounded-full"></div>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-14 w-14 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8" />
          </svg>
          <div class="w-20 h-1 bg-gradient-to-l from-transparent to-accent rounded-full"></div>
        </div>
        <h2 class="text-4xl md:text-6xl font-bold font-serif text-primary mb-6 drop-shadow-sm">
          空运-国际物流
        </h2>
        <p class="text-xl text-gray-700 max-w-3xl mx-auto leading-relaxed">
          快速高效的空运服务，覆盖全球主要机场，为您的货物提供最快捷的运输方案
        </p>
      </div>

      <!-- Hero Image for Air Freight -->
      <div class="mb-16 relative rounded-3xl overflow-hidden shadow-2xl">
        <img 
          src="https://images.unsplash.com/photo-1436491865332-7a61a109cc05?auto=format&fit=crop&q=80&w=2070" 
          alt="货运飞机" 
          class="w-full h-80 md:h-[500px] object-cover"
        />
        <div class="absolute inset-0 bg-gradient-to-t from-primary via-primary/60 to-transparent"></div>
        <div class="absolute bottom-0 left-0 right-0 p-8 md:p-12">
          <div class="bg-white/10 backdrop-blur-md rounded-2xl p-6 md:p-8 border border-white/20">
            <h3 class="text-3xl md:text-5xl font-bold text-white mb-4" style="text-shadow: 0 4px 20px rgba(0,0,0,0.5), 0 2px 4px rgba(0,0,0,0.3);">全球空运网络</h3>
            <p class="text-white text-lg md:text-xl max-w-2xl leading-relaxed" style="text-shadow: 0 2px 10px rgba(0,0,0,0.4);">
              与多家航空公司建立合作关系，提供固定舱位和优先处理服务，确保货物快速安全到达
            </p>
          </div>
        </div>
        <!-- 云朵装饰 -->
        <div class="absolute top-8 right-8 opacity-20">
          <svg class="w-32 h-32 fill-white" viewBox="0 0 24 24">
            <path d="M19.35 10.04C18.67 6.59 15.64 4 12 4 9.11 4 6.6 5.64 5.35 8.04 2.34 8.36 0 10.91 0 14c0 3.31 2.69 6 6 6h13c2.76 0 5-2.24 5-5 0-2.64-2.05-4.78-4.65-4.96z"/>
          </svg>
        </div>
      </div>

      <!-- Air Freight Services Grid -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        {airFreightServices.map((service, index) => (
          <div class="bg-white rounded-2xl shadow-lg border border-gray-200 overflow-hidden hover:shadow-2xl hover:border-accent/30 transition-all duration-300 group">
            <div class="p-8">
              <div class="flex items-start gap-6">
                <div class="w-16 h-16 bg-accent/10 rounded-xl flex items-center justify-center shrink-0 group-hover:bg-accent/20 transition-colors">
                  <span class="text-3xl font-bold text-accent">{String(index + 1).padStart(2, '0')}</span>
                </div>
                <div class="flex-1">
                  <h3 class="text-2xl font-bold text-primary mb-3 group-hover:text-accent transition-colors">{service.title}</h3>
                  <p class="text-gray-600 leading-relaxed mb-4">{service.description}</p>
                  
                  <div class="grid grid-cols-2 gap-3">
                    {service.features.map((feature) => (
                      <div class="flex items-center gap-2">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-accent shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                        </svg>
                        <span class="text-gray-700 font-medium">{feature}</span>
                      </div>
                    ))}
                  </div>
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Stats Section -->
  <section class="py-20 bg-gradient-to-br from-primary to-primary-light text-white relative overflow-hidden">
    <div class="absolute inset-0 opacity-10">
      <div class="absolute inset-0" style="background-image: radial-gradient(circle at 1px 1px, rgba(255,255,255,0.3) 1px, transparent 0); background-size: 40px 40px;"></div>
    </div>
    
    <div class="container relative z-10">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold mb-4 text-white" style="text-shadow: 0 4px 20px rgba(0,0,0,0.4);">我们的实力</h2>
        <p class="text-white text-lg" style="text-shadow: 0 2px 10px rgba(0,0,0,0.3);">多年深耕物流行业，为您提供专业可靠的服务</p>
      </div>
      
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
        <div class="text-center bg-white/15 rounded-2xl p-6 backdrop-blur-md border border-white/20">
          <div class="text-5xl md:text-6xl font-bold mb-3 text-accent" style="text-shadow: 0 4px 20px rgba(0,0,0,0.5);">80+</div>
          <div class="text-white text-lg font-medium" style="text-shadow: 0 2px 10px rgba(0,0,0,0.3);">服务国家</div>
        </div>
        <div class="text-center bg-white/15 rounded-2xl p-6 backdrop-blur-md border border-white/20">
          <div class="text-5xl md:text-6xl font-bold mb-3 text-accent" style="text-shadow: 0 4px 20px rgba(0,0,0,0.5);">240+</div>
          <div class="text-white text-lg font-medium" style="text-shadow: 0 2px 10px rgba(0,0,0,0.3);">服务网点</div>
        </div>
        <div class="text-center bg-white/15 rounded-2xl p-6 backdrop-blur-md border border-white/20">
          <div class="text-5xl md:text-6xl font-bold mb-3 text-accent" style="text-shadow: 0 4px 20px rgba(0,0,0,0.5);">1000+</div>
          <div class="text-white text-lg font-medium" style="text-shadow: 0 2px 10px rgba(0,0,0,0.3);">合作客户</div>
        </div>
        <div class="text-center bg-white/15 rounded-2xl p-6 backdrop-blur-md border border-white/20">
          <div class="text-5xl md:text-6xl font-bold mb-3 text-accent" style="text-shadow: 0 4px 20px rgba(0,0,0,0.5);">24/7</div>
          <div class="text-white text-lg font-medium" style="text-shadow: 0 2px 10px rgba(0,0,0,0.3);">全天候服务</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Routes Map Section with Animation -->
  <section class="section-padding bg-slate-50">
    <div class="container">
      <div class="text-center mb-16">
        <h2 class="text-4xl md:text-5xl font-bold font-serif text-primary mb-6">主要航线</h2>
        <p class="text-xl text-gray-700 max-w-2xl mx-auto font-medium">覆盖全球主要港口和机场，为您提供便捷高效的物流通道</p>
      </div>

      <!-- Sea Routes -->
      <div class="mb-16">
        <h3 class="text-2xl font-bold text-primary mb-8 flex items-center gap-3">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
          </svg>
          海运航线
        </h3>
        <div class="bg-white rounded-2xl shadow-lg p-8 border border-gray-200">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            {seaRoutes.map((route) => (
              <div class="route-card flex items-center gap-4 p-5 bg-gradient-to-r from-blue-50 to-white rounded-xl border-2 border-gray-200 hover:shadow-lg hover:border-accent/50 transition-all group">
                <div class="w-14 h-14 bg-primary rounded-xl flex items-center justify-center shrink-0 group-hover:bg-accent transition-colors shadow-md">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                  </svg>
                </div>
                <div class="flex-1">
                  <div class="font-bold text-primary text-lg mb-1 group-hover:text-accent transition-colors">{route.name}</div>
                  <div class="text-gray-600 text-sm font-medium">{route.ports}</div>
                </div>
                <div class="route-line">
                  <svg class="w-24 h-8" viewBox="0 0 100 30">
                    <path class="route-dash" d="M0,15 Q25,0 50,15 T100,15" fill="none" stroke="#FF9900" stroke-width="2.5" stroke-dasharray="5,5"/>
                    <circle cx="0" cy="15" r="5" fill="#003366"/>
                    <circle cx="100" cy="15" r="5" fill="#FF9900"/>
                  </svg>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>

      <!-- Air Routes -->
      <div>
        <h3 class="text-2xl font-bold text-primary mb-8 flex items-center gap-3">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8" />
          </svg>
          空运航线
        </h3>
        <div class="bg-white rounded-2xl shadow-lg p-8 border border-gray-200">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            {airRoutes.map((route) => (
              <div class="route-card flex items-center gap-4 p-5 bg-gradient-to-r from-orange-50 to-white rounded-xl border-2 border-gray-200 hover:shadow-lg hover:border-accent/50 transition-all group">
                <div class="w-14 h-14 bg-accent rounded-xl flex items-center justify-center shrink-0 shadow-md">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8" />
                  </svg>
                </div>
                <div class="flex-1">
                  <div class="font-bold text-primary text-lg mb-1 group-hover:text-accent transition-colors">{route.name}</div>
                  <div class="text-gray-600 text-sm font-medium">{route.airports}</div>
                </div>
                <div class="route-line">
                  <svg class="w-24 h-8" viewBox="0 0 100 30">
                    <path class="route-dash" d="M0,15 Q25,30 50,15 T100,15" fill="none" stroke="#003366" stroke-width="2.5" stroke-dasharray="5,5"/>
                    <circle cx="0" cy="15" r="5" fill="#003366"/>
                    <circle cx="100" cy="15" r="5" fill="#FF9900"/>
                  </svg>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-24 bg-gradient-to-br from-primary via-primary-light to-primary text-white relative overflow-hidden">
    <div class="absolute inset-0 opacity-5">
      <svg class="w-full h-full" viewBox="0 0 100 100" preserveAspectRatio="none">
        <defs>
          <pattern id="grid" width="10" height="10" patternUnits="userSpaceOnUse">
            <path d="M 10 0 L 0 0 0 10" fill="none" stroke="white" stroke-width="0.5"/>
          </pattern>
        </defs>
        <rect width="100%" height="100%" fill="url(#grid)"/>
      </svg>
    </div>
    
    <!-- 装饰元素 -->
    <div class="absolute top-10 left-10 opacity-10">
      <svg class="w-40 h-40 fill-white" viewBox="0 0 24 24">
        <path d="M12 2L1 21h22L12 2zm0 3.99L19.53 19H4.47L12 5.99z"/>
      </svg>
    </div>
    <div class="absolute bottom-10 right-10 opacity-10">
      <svg class="w-32 h-32 fill-white" viewBox="0 0 24 24">
